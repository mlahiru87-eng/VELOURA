{
  "entities": {
    "Video": {
      "title": "Video",
      "description": "Represents a video stream in the Veloura platform",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the video"
        },
        "description": {
          "type": "string",
          "description": "The detailed description of the video"
        },
        "category": {
          "type": "string",
          "description": "The video category"
        },
        "thumbnailUrl": {
          "type": "string",
          "description": "The cover image URL"
        },
        "videoUrl": {
          "type": "string",
          "description": "The direct video streaming source URL"
        },
        "duration": {
          "type": "string",
          "description": "Video duration in MM:SS format"
        },
        "views": {
          "type": "integer",
          "description": "Count of times the video has been viewed"
        },
        "featured": {
          "type": "boolean",
          "description": "Whether the video is featured on the billboard"
        },
        "premium": {
          "type": "boolean",
          "description": "Whether the video is restricted to premium tier"
        },
        "active": {
          "type": "boolean",
          "description": "Whether the video is visible to users"
        },
        "uploadDate": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of upload"
        },
        "likes": {
          "type": "integer",
          "description": "Count of positive reactions"
        },
        "dislikes": {
          "type": "integer",
          "description": "Count of negative reactions"
        },
        "favorites": {
          "type": "integer",
          "description": "Count of times the video was added to bookmarks/favorites"
        },
        "orientation": {
          "type": "string",
          "description": "Video orientation (landscape, portrait, square)"
        },
        "aspectRatio": {
          "type": "string",
          "description": "Video aspect ratio (e.g. 16:9, 9:16, 1:1)"
        },
        "resolution": {
          "type": "string",
          "description": "Video resolution string (e.g. 1920x1080)"
        },
        "width": {
          "type": "integer",
          "description": "Video width in pixels"
        },
        "height": {
          "type": "integer",
          "description": "Video height in pixels"
        },
        "fileSize": {
          "type": "integer",
          "description": "Video file size in bytes"
        }
      },
      "required": ["title", "category", "videoUrl"]
    },
    "User": {
      "title": "User",
      "description": "Represents a user profile with access roles",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "Role of the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["email", "role"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Represents a verified admin in the admins collection",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Admin email address"
        },
        "fullName": {
          "type": "string",
          "description": "Full name of the admin"
        },
        "role": {
          "type": "string",
          "enum": ["admin"],
          "description": "Role of the admin"
        },
        "active": {
          "type": "boolean",
          "description": "Active status of the admin"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["email", "fullName", "role", "active"]
    }
  },
  "firestore": {
    "videos/{videoId}": {
      "schema": "Video",
      "description": "Collection of cinematic video streams"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user roles and profiles"
    },
    "admins/{adminId}": {
      "schema": "Admin",
      "description": "Collection of administrators"
    }
  }
}
